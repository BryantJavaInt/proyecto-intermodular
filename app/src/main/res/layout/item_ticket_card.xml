<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardContainer"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginVertical="8dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="4dp">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Título de Incidencia"
            android:textSize="20sp"
            android:textColor="#264378"
            android:fontFamily="@font/montserratbold"
            android:layout_alignParentStart="true"
            android:layout_toStartOf="@+id/tvPrioridad"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tvPrioridad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ALTA"
            android:textSize="12sp"
            android:fontFamily="@font/montserratbold"
            android:layout_alignParentTop="true"
            android:layout_alignParentEnd="true"
            android:padding="4dp"/>

        <TextView
            android:id="@+id/tvFecha"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="12/03/2026"
            android:textSize="12sp"
            android:textColor="#999999"
            android:fontFamily="@font/montserratregular"
            android:layout_below="@id/tvTitulo"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvDescripcion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Descripción..."
            android:textSize="14sp"
            android:textColor="#555555"
            android:fontFamily="@font/montserratregular"
            android:layout_below="@id/tvFecha"
            android:maxLines="2"
            android:ellipsize="end"
            android:layout_marginBottom="12dp"/>

        <TextView
            android:id="@+id/tvEstado"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Abierta"
            android:textSize="14sp"
            android:fontFamily="@font/montserratbold"
            android:layout_below="@id/tvDescripcion"
            android:layout_alignParentEnd="true"
            android:padding="4dp"/>

    </RelativeLayout>
</androidx.cardview.widget.CardView>