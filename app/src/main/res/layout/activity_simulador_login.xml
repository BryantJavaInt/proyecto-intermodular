<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center"
    android:background="#F5F5F5">

    <ImageView
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:src="@drawable/logo_watermark"
        android:layout_marginBottom="24dp"
        android:alpha="0.8"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Simulador de Login"
        android:textSize="24sp"
        android:textColor="#264378"
        android:fontFamily="@font/montserratbold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="¿Con qué usuario quieres hacer la prueba?"
        android:textColor="#555555"
        android:fontFamily="@font/montserratregular"
        android:layout_marginBottom="32dp"
        android:textAlignment="center"/>

    <Button
        android:id="@+id/btnLoginInquilino"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Entrar como INQUILINO"
        android:textColor="#FFFFFF"
        android:backgroundTint="#2777da"
        android:fontFamily="@font/montserratbold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnLoginAgencia"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Entrar como AGENCIA"
        android:textColor="#FFFFFF"
        android:backgroundTint="#264378"
        android:fontFamily="@font/montserratbold"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btnLoginMantenimiento"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="Entrar como MANTENIMIENTO"
        android:textColor="#FFFFFF"
        android:backgroundTint="#4CAF50"
        android:fontFamily="@font/montserratbold" />

</LinearLayout>